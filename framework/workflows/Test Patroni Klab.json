      "id": "9d6b478f-8074-4b13-b0d6-db1b86e61be1",
      "name": "Check Readiness",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        656,
        496
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Grab the full JSON from Check Readiness\nconst result = $node[\"Check Readiness\"].json || {};\n\n// If the executeCommand node recorded an error, surface that cleanly\nif (result.error) {\n  return [\n    {\n      json: {\n        State: \"error\",\n        errorMessage: result.error.message || \"Unknown error in Check Readiness\",\n        stderr: result.stderr || \"\",\n        stdout: result.stdout || \"\",\n      },\n    },\n  ];\n}\n\n// No error object – now check stdout\nconst stdout = result.stdout;\n\nif (!stdout || typeof stdout !== \"string\") {\n  return [\n    {\n      json: {\n        State: \"error\",\n        errorMessage: \"Check Readiness produced no stdout JSON\",\n        stderr: result.stderr || \"\",\n        stdout: stdout,\n      },\n    },\n  ];\n}\n\n// Try to parse JSON from stdout\ntry {\n  const parsed = JSON.parse(stdout);\n  // Ensure we always provide State + debug fields\n  return [\n    {\n      json: {\n        ...parsed,\n        rawStdout: stdout,\n        stderr: result.stderr || \"\",\n      },\n    },\n  ];\n} catch (e) {\n  return [\n    {\n      json: {\n        State: \"error\",\n        errorMessage: \"Failed to parse JSON from Check Readiness\",\n        stderr: result.stderr || \"\",\n        stdout: stdout,\n        parseError: e.message,\n      },\n    },\n  ];\n}\n"
      },
